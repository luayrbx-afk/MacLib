        function elements:Dropdown(opt)
            local list = opt.List or {}
            local cb = opt.Callback or function() end
            local open = false

            local Frame = Create("Frame", {BorderSizePixel = 0, BackgroundColor3 = Color3.fromRGB(255, 255, 255), Size = UDim2.new(1, 0, 0, 22), BackgroundTransparency = 1, Parent = ContentScroll})
            Create("TextLabel", {BorderSizePixel = 0, TextXAlignment = Enum.TextXAlignment.Left, BackgroundColor3 = Color3.fromRGB(255, 255, 255), BackgroundTransparency = 1, Size = UDim2.new(1, -40, 1, 0), Text = opt.Name or "Dropdown", Parent = Frame})
            local DBar = Create("Frame", {BorderSizePixel = 0, BackgroundColor3 = Color3.fromRGB(220, 220, 220), Size = UDim2.new(0, 34, 0, 14), Position = UDim2.new(1, -40, 0, 4), Parent = Frame})
            Create("UICorner", {}, {DBar})
            local Arrow = Create("TextLabel", {BorderSizePixel = 0, BackgroundColor3 = Color3.fromRGB(255, 255, 255), BackgroundTransparency = 1, Size = UDim2.new(1, 0, 1, 0), Text = "›", Parent = DBar})
            local Btn = Create("TextButton", {BorderSizePixel = 0, BackgroundColor3 = Color3.fromRGB(255, 255, 255), BackgroundTransparency = 1, Size = UDim2.new(1, 0, 1, 0), Text = "", Parent = Frame})

            local DropContent = Create("Frame", {Visible = false, BorderSizePixel = 0, BackgroundColor3 = Color3.fromRGB(240, 240, 240), Size = UDim2.new(1, -10, 0, #list * 22), Position = UDim2.new(0, 5, 0, 22), Parent = Frame})
            Create("UICorner", {}, {DropContent})
            local DropScroll = Create("ScrollingFrame", {ScrollingDirection = Enum.ScrollingDirection.Y, BorderSizePixel = 0, BackgroundColor3 = Color3.fromRGB(255, 255, 255), Size = UDim2.new(1, 0, 1, 0), ScrollBarThickness = 2, BackgroundTransparency = 1, Parent = DropContent})
            Create("UIListLayout", {}, {DropScroll})

            for _, item in pairs(list) do
                local OptFrame = Create("Frame", {BorderSizePixel = 0, BackgroundColor3 = Color3.fromRGB(196, 196, 196), Size = UDim2.new(1, 0, 0, 22), BackgroundTransparency = 1, Parent = DropScroll})
                Create("TextLabel", {BorderSizePixel = 0, TextXAlignment = Enum.TextXAlignment.Left, BackgroundColor3 = Color3.fromRGB(255, 255, 255), BackgroundTransparency = 1, Size = UDim2.new(1, -20, 1, 0), Text = item, Position = UDim2.new(0, 4, 0, 0), Parent = OptFrame})
                local OBtn = Create("TextButton", {BorderSizePixel = 0, BackgroundColor3 = Color3.fromRGB(255, 255, 255), BackgroundTransparency = 1, Size = UDim2.new(1, 0, 1, 0), Text = "", Parent = OptFrame})
                OBtn.MouseButton1Click:Connect(function()
                    cb(item)
                    open = false
                    Arrow.Rotation = 0
                    DropContent.Visible = false
                    Tween(Frame, {Size = UDim2.new(1, 0, 0, 22)}, 0.2)
                end)
            end

            Btn.MouseButton1Click:Connect(function()
                open = not open
                if open then
                    Tween(Arrow, {Rotation = 90}, 0.2)
                    Tween(Frame, {Size = UDim2.new(1, 0, 0, 22 + (#list * 22))}, 0.2)
                    DropContent.Visible = true
                else
                    Tween(Arrow, {Rotation = 0}, 0.2)
                    Tween(Frame, {Size = UDim2.new(1, 0, 0, 22)}, 0.2).Completed:Connect(function() DropContent.Visible = false end)
                end
            end)
        end

        function elements:Label(text)
            local Frame = Create("Frame", {BorderSizePixel = 0, BackgroundColor3 = Color3.fromRGB(255, 255, 255), Size = UDim2.new(1, 0, 0, 22), BackgroundTransparency = 1, Parent = ContentScroll})
            Create("TextLabel", {BorderSizePixel = 0, TextXAlignment = Enum.TextXAlignment.Left, BackgroundColor3 = Color3.fromRGB(255, 255, 255), BackgroundTransparency = 1, RichText = true, Size = UDim2.new(1, 0, 1, 0), Text = text, Parent = Frame})
        end

        return elements
    end

    return winData
end

return MacUI
