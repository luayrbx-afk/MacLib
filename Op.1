        function elements:Slider(opt)
            local min = opt.Min or 0
            local max = opt.Max or 100
            local def = opt.Default or min
            local cb = opt.Callback or function() end

            local Frame = Create("Frame", {BorderSizePixel = 0, BackgroundColor3 = Color3.fromRGB(255, 255, 255), Size = UDim2.new(1, 0, 0, 32), BackgroundTransparency = 1, Parent = ContentScroll})
            Create("TextLabel", {BorderSizePixel = 0, TextXAlignment = Enum.TextXAlignment.Left, BackgroundColor3 = Color3.fromRGB(255, 255, 255), BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 22), Text = opt.Name or "Slider", Parent = Frame})
            
            local SBar = Create("Frame", {BorderSizePixel = 0, BackgroundColor3 = Color3.fromRGB(220, 220, 220), Size = UDim2.new(1, -10, 0, 8), Position = UDim2.new(0, 5, 0, 22), Parent = Frame})
            Create("UICorner", {}, {SBar})
            local SDot = Create("Frame", {BorderSizePixel = 0, BackgroundColor3 = Color3.fromRGB(173, 255, 192), Size = UDim2.new(0, 14, 0, 14), Position = UDim2.new(0, 0, 0, -3), Parent = SBar})
            Create("UICorner", {}, {SDot})
            local SVal = Create("TextLabel", {BorderSizePixel = 0, TextSize = 10, BackgroundColor3 = Color3.fromRGB(255, 255, 255), BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 14), Text = tostring(def), Position = UDim2.new(0, 0, 0, 8), Parent = SBar})

            local dragging = false
            SDot.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = true end
            end)
            UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then dragging = false end
            end)

            UserInputService.InputChanged:Connect(function(input)
                if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                    local sizeX = math.clamp((input.Position.X - SBar.AbsolutePosition.X) / SBar.AbsoluteSize.X, 0, 1)
                    local value = math.floor(min + ((max - min) * sizeX))
                    Tween(SDot, {Position = UDim2.new(sizeX, -7, 0, -3)}, 0.05)
                    SVal.Text = tostring(value)
                    cb(value)
                end
            end)

            local initialSize = (def - min) / (max - min)
            SDot.Position = UDim2.new(initialSize, -7, 0, -3)
            cb(def)
        end

        function elements:Textbox(opt)
            local cb = opt.Callback or function() end
            local Frame = Create("Frame", {BorderSizePixel = 0, BackgroundColor3 = Color3.fromRGB(255, 255, 255), Size = UDim2.new(1, 0, 0, 22), BackgroundTransparency = 1, Parent = ContentScroll})
